              <path
                fill="#EA4335"
                d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
              />
            </svg>
            Google
          </a>
          <a
            href="https://www.facebook.com/p/Carter-Quality-Construction-100063756949389/"
            target="_blank"
            rel="noopener noreferrer"
            class="social-btn facebook"
            aria-label="Follow Carter Quality Construction on Facebook"
            title="Follow us on Facebook"
          >
            <svg
              viewBox="0 0 24 24"
              width="24"
              height="24"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
                fill="currentColor"
              />
            </svg>
            Facebook
          </a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>
          &copy; <span id="currentYear">2024</span> Carter Quality Construction.
          All rights reserved.
        </p>
      </div>
    </footer>

    <!-- Back to Top Button (outside page-grid) -->
    <button id="backToTop" aria-label="Back to top">
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <path d="M18 15l-6-6-6 6" />
      </svg>
    </button>

    <!-- Update copyright year dynamically -->
    <script>
      document.getElementById("currentYear").textContent =
        new Date().getFullYear();
    </script>

    <script>
      // ==========================================
      // PERFORMANCE-OPTIMIZED ANIMATION ENGINE
      // ==========================================

      (function () {
        "use strict";

        // Throttle function for scroll performance
        const throttle = (func, limit) => {
          let inThrottle;
          return function () {
            const args = arguments;
            const context = this;
            if (!inThrottle) {
              func.apply(context, args);
              inThrottle = true;
              setTimeout(() => (inThrottle = false), limit);
            }
          };
        };

        // Request Animation Frame manager
        let rafId = null;
        let lastScrollY = 0;
        let ticking = false;

        // Mobile detection for performance optimizations
        const isMobile = window.innerWidth <= 768;
        const isLowEndDevice = navigator.hardwareConcurrency <= 4 || isMobile;

        // ==========================================
        // PARALLAX EFFECT
        // ==========================================
        const initParallax = () => {
          const parallaxLayers = document.querySelectorAll(".parallax-layer");
          if (parallaxLayers.length === 0) return;

          const updateParallax = () => {
            const scrollY = window.pageYOffset;
            const heroHeight =
              document.querySelector(".hero")?.offsetHeight || 0;

            // Only apply parallax within hero section
            if (scrollY <= heroHeight) {
              parallaxLayers.forEach((layer) => {
                const speed = layer.classList.contains("parallax-bg")
                  ? 0.3
                  : layer.classList.contains("parallax-mid")
                    ? 0.5
                    : 0.7;
                const yPos = -(scrollY * speed);
                layer.style.transform = `translate3d(0, ${yPos}px, 0)`;
              });
            }
          };

          // Use requestAnimationFrame for smooth parallax
          const onScroll = () => {
            lastScrollY = window.pageYOffset;
            if (!ticking) {
              rafId = requestAnimationFrame(() => {
                updateParallax();
                ticking = false;
              });
              ticking = true;
            }
          };

          window.addEventListener("scroll", onScroll, { passive: true });
          updateParallax(); // Initial call
        };

        // ==========================================
        // STAGGERED REVEAL ANIMATIONS
        // ==========================================
        const initStaggeredReveals = () => {
          const containers = document.querySelectorAll(
            ".stagger-reveal-container",
          );
          if (containers.length === 0) return;

          const observerOptions = {
            root: null,
            rootMargin: isMobile ? "0px 0px -10% 0px" : "0px 0px -20% 0px",
            threshold: 0.1,
          };

          const observerCallback = (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                const container = entry.target;
                const children = container.querySelectorAll(".stagger-reveal");

                children.forEach((child, index) => {
                  // Add stagger delay class
                  const delayClass = `stagger-delay-${Math.min(index, 9)}`;
                  child.classList.add(delayClass);

                  // Trigger animation with slight delay
                  setTimeout(
                    () => {
                      child.classList.add("visible");
                    },
                    isMobile ? index * 80 : index * 120,
                  );
                });

                // Unobserve after animation triggered
                observer.unobserve(container);
              }
            });
          };

          const observer = new IntersectionObserver(
            observerCallback,
            observerOptions,
          );
          containers.forEach((container) => observer.observe(container));
        };

        // ==========================================
        // SCROLL-TRIGGERED ANIMATIONS (FADE-IN)
        // ==========================================
        const initScrollAnimations = () => {
          const animatedElements = document.querySelectorAll(
            ".fade-in, .scale-in, .slide-in-left, .slide-in-right, .section-reveal",
          );

          if (animatedElements.length === 0) return;

          const observerOptions = {
            root: null,
            rootMargin: isMobile ? "0px 0px -15% 0px" : "0px 0px -25% 0px",
            threshold: 0.1,
          };

          const observerCallback = (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("visible");
                // Optional: unobserve after animation
                // observer.unobserve(entry.target);
              }
            });
          };

          const observer = new IntersectionObserver(
            observerCallback,
            observerOptions,
          );
          animatedElements.forEach((el) => observer.observe(el));
        };

        // ==========================================
        // MAGNETIC BUTTON EFFECT
        // ==========================================
        const initMagneticButtons = () => {
          if (isLowEndDevice) return; // Skip on low-end devices

          const buttons = document.querySelectorAll(
            ".btn, .mobile-cta-btn, .submit-btn",
          );

          buttons.forEach((btn) => {
            btn.classList.add("magnetic-btn");

            btn.addEventListener("mousemove", (e) => {
              const rect = btn.getBoundingClientRect();
              const x = e.clientX - rect.left - rect.width / 2;
              const y = e.clientY - rect.top - rect.height / 2;

              // Magnetic pull strength
              const strength = 0.3;
              btn.style.transform = `translate(${x * strength}px, ${y * strength}px)`;
            });

            btn.addEventListener("mouseleave", () => {
              btn.style.transform = "translate(0, 0)";
            });
          });
        };

        // ==========================================
        // COUNTER ANIMATION
        // ==========================================
        const initCounterAnimation = () => {
          const counters = document.querySelectorAll(".counter-number");
          if (counters.length === 0) return;

          const animateCounter = (element, target) => {
            const duration = 2000;
            const start = 0;
            const startTime = performance.now();

            const update = (currentTime) => {
              const elapsed = currentTime - startTime;
              const progress = Math.min(elapsed / duration, 1);

              // Easing function (ease-out-cubic)
              const easeOut = 1 - Math.pow(1 - progress, 3);
              const current = Math.floor(start + (target - start) * easeOut);

              element.textContent = current;

              if (progress < 1) {
                requestAnimationFrame(update);
              } else {
                element.textContent = target;
              }
            };

            requestAnimationFrame(update);
          };

          const observerOptions = {
            threshold: 0.5,
          };

          const observerCallback = (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                const target = parseInt(entry.target.dataset.count, 10);
                animateCounter(entry.target, target);
                observer.unobserve(entry.target);
              }
            });
          };

          const observer = new IntersectionObserver(
            observerCallback,
            observerOptions,
          );
          counters.forEach((counter) => observer.observe(counter));
        };

        // ==========================================
        // PROGRESS BAR ANIMATION
        // ==========================================
        const initProgressBars = () => {
          const progressBars = document.querySelectorAll(".progress-fill");
          if (progressBars.length === 0) return;

          const observerOptions = {
            threshold: 0.5,
          };

          const observerCallback = (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("animate");
                observer.unobserve(entry.target);
              }
            });
          };

          const observer = new IntersectionObserver(
            observerCallback,
            observerOptions,
          );
          progressBars.forEach((bar) => observer.observe(bar));
        };

        // ==========================================
        // IMAGE REVEAL ANIMATION
        // ==========================================
        const initImageReveal = () => {
          const images = document.querySelectorAll(".image-reveal");
          if (images.length === 0) return;

          const observerOptions = {
            threshold: 0.3,
          };

          const observerCallback = (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("visible");
                observer.unobserve(entry.target);
              }
            });
          };

          const observer = new IntersectionObserver(
            observerCallback,
            observerOptions,
          );
          images.forEach((img) => observer.observe(img));
        };

        // ==========================================
        // SERVICE CARD ORANGE HIGHLIGHT ON SCROLL
        // ==========================================
        const initServiceCardHighlights = () => {
          const serviceCards = document.querySelectorAll(".service-card");
          if (serviceCards.length === 0) return;

          const observerOptions = {
            root: null,
            rootMargin: isMobile ? "0px 0px -10% 0px" : "0px 0px -20% 0px",
            threshold: 0.2,
          };

          const observerCallback = (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("in-viewport");
              } else {
                // Remove class when out of view to allow re-triggering
                entry.target.classList.remove("in-viewport");
              }
            });
          };

          const observer = new IntersectionObserver(
            observerCallback,
            observerOptions,
          );
          serviceCards.forEach((card) => observer.observe(card));
        };

        // ==========================================
        // MOBILE CARD GLOW EFFECT ON SCROLL
        // ==========================================
        const initMobileCardGlow = () => {
          if (!isMobile) return;

          const glowCards = document.querySelectorAll(".mobile-card-glow");
          if (glowCards.length === 0) return;

          const observerOptions = {
            root: null,
            rootMargin: "0px 0px -15% 0px",
            threshold: 0.15,
          };

          const observerCallback = (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("in-viewport");
              } else {
                entry.target.classList.remove("in-viewport");
              }
            });
          };

          const observer = new IntersectionObserver(
            observerCallback,
            observerOptions,
          );
          glowCards.forEach((card) => observer.observe(card));
        };

        // ==========================================
        // MOBILE IMAGE REVEAL ON SCROLL
        // ==========================================
        const initMobileImageReveal = () => {
          if (!isMobile) return;

          const revealImages = document.querySelectorAll(".image-reveal");
          if (revealImages.length === 0) return;

          const observerOptions = {
            root: null,
            rootMargin: "0px 0px -10% 0px",
            threshold: 0.2,
          };

          const observerCallback = (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("revealed", "visible");
                observer.unobserve(entry.target);
              }
            });
          };

          const observer = new IntersectionObserver(
            observerCallback,
            observerOptions,
          );
          revealImages.forEach((img) => observer.observe(img));
        };

        // ==========================================
        // TOUCH OPTIMIZATIONS
        // ==========================================
        const initTouchOptimizations = () => {
          if (!("ontouchstart" in window)) return;

          // Add touch feedback classes
          const interactiveElements = document.querySelectorAll(
            ".btn, .service-card, .contact-item, .feature",
          );

          interactiveElements.forEach((el) => {
            el.addEventListener(
              "touchstart",
              () => {
                el.classList.add("touch-active");
              },
              { passive: true },
            );

            el.addEventListener(
              "touchend",
              () => {
                setTimeout(() => {
                  el.classList.remove("touch-active");
                }, 150);
              },
              { passive: true },
            );
          });

          // Improve scroll performance on iOS
          document.body.addEventListener(
            "touchmove",
            () => {
              // Force GPU acceleration during scroll
            },
            { passive: true },
          );
        };

        // ==========================================
        // PERFORMANCE MONITORING
        // ==========================================
        const initPerformanceMonitoring = () => {
          if (process.env.NODE_ENV === "production") return;

          // Log animation performance
          let frameCount = 0;
          let lastTime = performance.now();

          const measureFPS = () => {
            frameCount++;
            const currentTime = performance.now();

            if (currentTime - lastTime >= 1000) {
              const fps = frameCount;
              frameCount = 0;
              lastTime = currentTime;

              if (fps < 50) {
                console.warn(
                  `Low FPS detected: ${fps}. Consider reducing animation complexity.`,
                );
              }
            }

            requestAnimationFrame(measureFPS);
          };

          // Uncomment to enable FPS monitoring
          // measureFPS();
        };

        // ==========================================
        // INITIALIZE ALL ANIMATIONS
        // ==========================================
        const init = () => {
          initParallax();
          initStaggeredReveals();
          initScrollAnimations();
          initMagneticButtons();
          initCounterAnimation();
          initProgressBars();
          initImageReveal();
          initServiceCardHighlights();
          initMobileCardGlow();
          initMobileImageReveal();
          initTouchOptimizations();
          initPerformanceMonitoring();

          // Add loaded class to body for initial animations
          document.body.classList.add("animations-loaded");
        };

        // Run on DOM ready
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", init);
        } else {
          init();
        }

        // Handle resize - no reload needed, observers adjust automatically
        // Removed aggressive reload that caused infinite loops on mobile
      })();

      // ==========================================
      // HERO VIDEO HANDLER
      // - Ensures autoplay works across browsers
      // - Implements lazy loading with IntersectionObserver
      // - Handles mobile data-saver mode
      // - Provides fallback for autoplay blockers
      // ==========================================
      (function () {
        "use strict";

        var heroVideo = document.querySelector(".hero-video-background video");
        if (!heroVideo) return;

        // Ensure muted state (required for autoplay)
        heroVideo.muted = true;
        heroVideo.defaultMuted = true;

        // Handle video errors with fallback
        heroVideo.addEventListener("error", function () {
          var container = heroVideo.closest(".hero-video-background");
          if (container) {
            container.classList.add("video-fallback");
          }
        });

        // Handle individual source errors
        var sources = heroVideo.querySelectorAll("source");
        sources.forEach(function (source) {
          source.addEventListener("error", function () {
            console.warn("Video source failed to load:", this.src);
          });
        });

        // Attempt autoplay with error handling
        var playPromise = heroVideo.play();
        if (playPromise !== undefined) {
          playPromise.catch(function (error) {
            console.log("Video autoplay prevented:", error);
            var container = heroVideo.closest(".hero-video-background");
            if (container) {
              container.classList.add("video-fallback");
            }
          });
        }

        // Handle visibility change (pause when tab is hidden)
        document.addEventListener("visibilitychange", function () {
          if (document.hidden) {
            heroVideo.pause();
          } else {
            heroVideo.play().catch(function () {});
          }
        });

        // Handle connection changes (mobile data saving)
        if ("connection" in navigator) {
          var connection = navigator.connection;
          if (
            connection.saveData ||
            connection.effectiveType === "slow-2g" ||
            connection.effectiveType === "2g"
          ) {
            // User has data-saver enabled or slow connection - show poster only
            heroVideo.pause();
            heroVideo.removeAttribute("autoplay");
            var container = heroVideo.closest(".hero-video-background");
            if (container) {
              container.classList.add("video-fallback");
            }
            return;
          }
        }

        // Check for reduced motion preference
        var prefersReducedMotion = window.matchMedia(
          "(prefers-reduced-motion: reduce)",
        );
        if (prefersReducedMotion.matches) {
          heroVideo.pause();
          heroVideo.removeAttribute("autoplay");
        }

        // Listen for changes in reduced motion preference
        prefersReducedMotion.addEventListener("change", function (e) {
          if (e.matches) {
            heroVideo.pause();
          } else {
            heroVideo.play().catch(function () {});
          }
        });
      })();

      // ==========================================
      // EXISTING SITE FUNCTIONALITY
      // ==========================================

      // Mobile menu toggle - REMOVED (replaced with horizontal nav bar)

      // Navbar scroll effect - maintain consistent background
      let navbarElement = document.getElementById("navbar");

      window.addEventListener(
        "scroll",
        () => {
          // Keep background color constant, only adjust box-shadow if needed
          navbar.style.background = "#040809";
        },
        { passive: true },
      );

      // Reveal navigation bar on first scroll
      let navRevealed = false;
      window.addEventListener("scroll", function () {
        if (!navRevealed && window.scrollY > 0) {
          const navbar = document.getElementById("navbar");
          navbar.classList.add("visible");
          navRevealed = true;
        }
      });

      // Back to top button
      const backToTopBtn = document.getElementById("backToTop");

      window.addEventListener(
        "scroll",
        () => {
          if (window.pageYOffset > 300) {
            backToTopBtn.style.opacity = "1";
            backToTopBtn.style.visibility = "visible";
            backToTopBtn.style.transform = "translateY(0)";
          } else {
            backToTopBtn.style.opacity = "0";
            backToTopBtn.style.visibility = "hidden";
            backToTopBtn.style.transform = "translateY(20px)";
          }
        },
        { passive: true },
      );

      backToTopBtn.addEventListener("click", () => {
        window.scrollTo({
          top: 0,
          behavior: "smooth",
        });
      });

      // Home navigation links - scroll to top (same as back-to-top button)
      // Must be added BEFORE the generic anchor handler to use stopImmediatePropagation
      document.querySelectorAll('a[href="#home"]').forEach((homeLink) => {
        homeLink.addEventListener("click", function (e) {
          e.preventDefault();
          e.stopImmediatePropagation();
          window.scrollTo({
            top: 0,
            behavior: "smooth",
          });
          // Update aria-current to indicate active page
          document.querySelectorAll(".nav-links a").forEach((link) => {
            link.removeAttribute("aria-current");
          });
          this.setAttribute("aria-current", "page");
        });
      });

      // Form validation and submission
      (function () {
        const contactForm = document.getElementById("contactForm");
        const submitBtn = contactForm.querySelector(".submit-btn");

        // Validation patterns
        const patterns = {
          name: /^[a-zA-Z\s]{2,50}$/,
          email: /^[^\s@]+@[^\s@]+\.[^\s@]+$/,
          phone: /^[\d\s\-\(\)\+]{10,20}$/,
        };

        // Real-time validation
        const formFields = contactForm.querySelectorAll(
          'input[type="text"], input[type="email"], input[type="tel"], textarea, select',
        );

        formFields.forEach((field) => {
          field.addEventListener("blur", () => validateField(field));
          field.addEventListener("input", () => {
            if (field.classList.contains("error")) {
              validateField(field);
            }
          });
        });

        function validateField(field) {
          const value = field.value.trim();
          const fieldName = field.name;
          const errorSpan = field.parentElement.querySelector(".error-message");

          // Remove existing states
          field.classList.remove("error", "success");

          if (field.required && !value) {
            showError(field, "This field is required");
            return false;
          }

          if (patterns[fieldName] && !patterns[fieldName].test(value)) {
            let message = "Invalid format";
            switch (fieldName) {
              case "name":
                message = "Please enter a valid name (letters only)";
                break;
              case "email":
                message = "Please enter a valid email address";
                break;
              case "phone":
                message = "Please enter a valid phone number";
                break;
            }
            showError(field, message);
            return false;
          }

          if (value && !patterns[fieldName]) {
            field.classList.add("success");
          }

          if (errorSpan) {
            errorSpan.style.display = "none";
          }

          return true;
        }

        function showError(field, message) {
          field.classList.add("error");
          let errorSpan = field.parentElement.querySelector(".error-message");
          if (!errorSpan) {
            errorSpan = document.createElement("span");
            errorSpan.className = "error-message";
            field.parentElement.appendChild(errorSpan);
          }
          errorSpan.textContent = message;
          errorSpan.style.display = "block";
        }

        // Form submission
        contactForm.addEventListener("submit", async (e) => {
          e.preventDefault();

          // Validate all fields
          let isValid = true;
          formFields.forEach((field) => {
            if (!validateField(field)) {
              isValid = false;
            }
          });

          if (!isValid) {
            // Focus on first error field
            const firstError = contactForm.querySelector(".error");
            if (firstError) {
              firstError.focus();
            }
            return;
          }

          // Show loading state
          submitBtn.classList.add("loading");
          submitBtn.disabled = true;
          const originalText = submitBtn.textContent;
          submitBtn.textContent = "Sending...";

          // Submit to FormSubmit
          try {
            const formData = new FormData(contactForm);
            const response = await fetch(
              "https://formsubmit.co/ajax/carterqualityc@gmail.com",
              {
                method: "POST",
                body: formData,
                headers: {
                  Accept: "application/json",
                },
              },
            );

            const result = await response.json();

            if (result.success) {
              // Show success message
              showSuccessMessage();

              // Reset form
              contactForm.reset();

              // Remove success states
              formFields.forEach((field) => {
                field.classList.remove("success");
              });
            } else {
              // Show error message
              alert(
                "There was an error sending your message. Please try again or call us directly at (715) 644-8050.",
              );
            }
          } catch (error) {
            // Show error message
            alert(
              "There was an error sending your message. Please try again or call us directly at (715) 644-8050.",
            );
          } finally {
            // Reset button state
            submitBtn.classList.remove("loading");
            submitBtn.disabled = false;
            submitBtn.textContent = originalText;
          }
        });

        function showSuccessMessage() {
          // Create success overlay
          const overlay = document.createElement("div");
          overlay.style.cssText = `
          position: fixed;
          top: 0;
          left: 0;
          right: 0;
          bottom: 0;
          background: rgba(0, 0, 0, 0.5);
          display: flex;
          align-items: center;
          justify-content: center;
          z-index: 10000;
          animation: fadeIn 0.3s ease;
        `;

          const modal = document.createElement("div");
          modal.style.cssText = `
          background: var(--card-bg);
          padding: 3rem;
          border-radius: 20px;
          max-width: 500px;
          width: 90%;
          border: 1px solid var(--border-color);
          text-align: center;
          box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
          animation: slideUp 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        `;

          modal.innerHTML = `
          <div style="
            width: 80px;
            height: 80px;
            background: var(--gradient);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            font-size: 2.5rem;
            color: white;
          ">✓</div>
          <h3 style="
            font-size: 1.75rem;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 1rem;
          ">Message Sent Successfully!</h3>
          <p style="
            font-size: 1.1rem;
            color: var(--text-secondary);
            line-height: 1.6;
            margin-bottom: 2rem;
          ">Thank you for contacting Carter Quality Construction. We'll review your message and get back to you within 24 hours.</p>
          <button onclick="this.closest('div[style*=fixed]').remove()" style="
            padding: 1rem 2rem;
            background: var(--gradient);
            color: var(--black);
            border: none;
            border-radius: 12px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
          " onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'">Got it!</button>
        `;

          overlay.appendChild(modal);
          document.body.appendChild(overlay);

          // Close on backdrop click
          overlay.addEventListener("click", (e) => {
            if (e.target === overlay) {
              overlay.remove();
            }
          });
        }
      })();

      // Testimonials Slider
      (function () {
        const testimonialSlides =
          document.querySelectorAll(".testimonial-slide");
        const prevBtn = document.getElementById("prevBtn");
        const nextBtn = document.getElementById("nextBtn");
        const sliderContainer = document.querySelector(".testimonials-slider");
        let currentSlide = 0;
        let autoSlideInterval;

        // Set a fixed height for the slider container to prevent layout shifts
        sliderContainer.style.height = "480px";
        sliderContainer.style.minHeight = "480px";

        // Create single navigation container
        const sliderNav = document.createElement("div");
        sliderNav.className = "slider-nav";

        // Create navigation dots (one for each slide)
        testimonialSlides.forEach((_, index) => {
          const dot = document.createElement("div");
          dot.className = `slider-dot ${index === 0 ? "active" : ""}`;
          dot.dataset.slideIndex = index;
          dot.addEventListener("click", () => goToSlide(index));
          sliderNav.appendChild(dot);
        });

        // Place nav container in the slider container (NOT in slides)
        sliderContainer.appendChild(sliderNav);

        // Query dots AFTER they're added to the DOM
        const dots = document.querySelectorAll(".slider-dot");

        function goToSlide(index) {
          // Remove active class from current slide and dot
          testimonialSlides[currentSlide].classList.remove("active");
          dots[currentSlide].classList.remove("active");

          // Update current slide index
          currentSlide = index;

          // Add active class to new slide and dot
          testimonialSlides[currentSlide].classList.add("active");
          dots[currentSlide].classList.add("active");
        }

        function nextSlide() {
          const next = (currentSlide + 1) % testimonialSlides.length;
          goToSlide(next);
        }

        function prevSlide() {
          const prev =
            (currentSlide - 1 + testimonialSlides.length) %
            testimonialSlides.length;
          goToSlide(prev);
        }

        // Event listeners for arrows
        nextBtn.addEventListener("click", () => {
          nextSlide();
          resetAutoSlide();
        });

        prevBtn.addEventListener("click", () => {
          prevSlide();
          resetAutoSlide();
        });

        // Auto-slide functionality
        function startAutoSlide() {
          autoSlideInterval = setInterval(nextSlide, 5000);
        }

        function resetAutoSlide() {
          clearInterval(autoSlideInterval);
          startAutoSlide();
        }

        // Start auto-slide on page load
        startAutoSlide();

        // Pause auto-slide on hover
        sliderContainer.addEventListener("mouseenter", () => {
          clearInterval(autoSlideInterval);
        });

        sliderContainer.addEventListener("mouseleave", () => {
          startAutoSlide();
        });

        // Touch support for mobile
        let touchStartX = 0;
        let touchEndX = 0;

        sliderContainer.addEventListener(
          "touchstart",
          (e) => {
            touchStartX = e.changedTouches[0].screenX;
            clearInterval(autoSlideInterval);
          },
          { passive: true },
        );

        sliderContainer.addEventListener(
          "touchend",
          (e) => {
            touchEndX = e.changedTouches[0].screenX;
            handleSwipe();
            startAutoSlide();
          },
          { passive: true },
        );

        function handleSwipe() {
          const swipeThreshold = 50;
          const diff = touchStartX - touchEndX;

          if (Math.abs(diff) > swipeThreshold) {
            if (diff > 0) {
              nextSlide();
            } else {
              prevSlide();
            }
          }
        }

        // Smooth scroll for anchor links
        document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
          anchor.addEventListener("click", function (e) {
            e.preventDefault();
            const target = document.querySelector(this.getAttribute("href"));
            if (target) {
              target.scrollIntoView({
                behavior: "smooth",
                block: "start",
              });
            }
          });
        });

        // Navigation bar reveal on scroll
        let hasScrolled = false;
        window.addEventListener("scroll", function () {
          if (!hasScrolled && window.scrollY > 0) {
            navbar.classList.add("visible");
            hasScrolled = true;
          }
        });
      })();
    </script>
    <!--
      Mobile‑first navigation bar scroll handling
      -------------------------------------------------
      The navbar is initially hidden (translated off‑screen) and becomes
      visible when the user scrolls down. Once the page is scrolled past a
      small threshold (50 px), a solid black background is applied for better
      contrast on mobile devices.

      The script uses a `requestAnimationFrame` loop to throttle the scroll
      event, which is more efficient on mobile browsers than handling every
      `scroll` event directly. A simple fallback is provided for very old
      browsers that lack `requestAnimationFrame`.
    -->
    <script>
      (function () {
        var navbar = document.getElementById("navbar");
        if (!navbar) return; // safety check

        var lastScrollY = 0;
        var ticking = false;
        var SCROLL_THRESHOLD = 50; // px before applying solid background

        function onScroll() {
          lastScrollY = window.scrollY || window.pageYOffset;
          requestTick();
        }

        function requestTick() {
          if (!ticking) {
            // Use requestAnimationFrame if available, otherwise fallback to setTimeout
            if (window.requestAnimationFrame) {
              window.requestAnimationFrame(update);
            } else {
              setTimeout(update, 66); // ~15fps fallback
            }
            ticking = true;
          }
        }

        function update() {
          // Show navbar when any scroll occurs
          if (lastScrollY > 0) {
            navbar.classList.add("visible");
          } else {
            navbar.classList.remove("visible");
          }

          // Apply solid background after threshold (mobile‑first)
          if (lastScrollY > SCROLL_THRESHOLD) {
            navbar.classList.add("scrolled");
          } else {
            navbar.classList.remove("scrolled");
          }
          ticking = false;
        }

        // Attach scroll listener
        window.addEventListener("scroll", onScroll, { passive: true });
        // Initialise state on load (in case page is loaded with scroll offset)
        onScroll();
      })();
    </script>
  </body>
</html>
